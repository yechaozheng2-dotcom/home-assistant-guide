---
interface Props {
  asin: string;
  title: string;
  description?: string;
  rating?: number;
  price?: string;
  badge?: string;
  image?: string;
}

const STORE_ID = 'yechaozheng-20';
const { asin, title, description, rating, price, badge, image } = Astro.props;

const affiliateUrl = `https://www.amazon.com/dp/${asin}?tag=${STORE_ID}`;
const stars = rating ? Array.from({ length: 5 }, (_, i) => i < Math.round(rating)) : null;
---

<div class={`border border-[var(--color-border)] rounded-xl p-4 bg-[var(--color-surface)] hover:shadow-sm transition-shadow border-l-4 border-l-[var(--color-accent)] my-4 ${image ? 'flex gap-4' : ''}`}>
  {image && (
    <a href={affiliateUrl} target="_blank" rel="noopener noreferrer nofollow" class="flex-shrink-0">
      <img src={image} alt={title} class="w-24 h-24 object-contain rounded-lg" loading="lazy" />
    </a>
  )}
  <div class="flex-1 min-w-0">
    <div class="flex items-start justify-between gap-2 flex-wrap mb-1">
      <h3 class="font-semibold text-[var(--color-heading)] leading-snug">{title}</h3>
      {badge && <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full bg-green-100 text-green-800 flex-shrink-0">{badge}</span>}
    </div>
    {description && <p class="text-sm text-[var(--color-muted)] mt-1">{description}</p>}
    <div class="flex items-center justify-between mt-3 flex-wrap gap-2">
      <div class="flex items-center gap-2">
        {stars && (
          <div class="flex gap-0.5 text-sm">
            {stars.map(filled => (
              <span class={filled ? 'text-[var(--color-accent-warm)]' : 'text-[var(--color-border)]'}>★</span>
            ))}
          </div>
        )}
        {price && <span class="text-sm font-semibold text-[var(--color-heading)]">{price}</span>}
      </div>
      <a
        href={affiliateUrl}
        target="_blank"
        rel="noopener noreferrer nofollow"
        class="text-sm font-semibold text-white bg-[var(--color-accent)] px-4 py-1.5 rounded-lg hover:opacity-90 transition-opacity"
      >
        View on Amazon →
      </a>
    </div>
  </div>
</div>
