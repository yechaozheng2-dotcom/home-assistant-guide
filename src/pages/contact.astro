---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Home Assistant Guide"
  description="Get in touch with the Home Assistant Guide team for questions, automation ideas, or partnership inquiries."
>
  <div class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-[var(--color-heading)] mb-4" style="font-family: 'Lora', serif;">Contact Us</h1>
    <p class="text-[var(--color-muted)] mb-8">Have a question about Home Assistant, an automation idea, or a partnership inquiry? We'd love to hear from you.</p>

    <div class="prose prose-lg max-w-none prose-a:text-[var(--color-accent)]">
      <h2>Get in Touch</h2>
      <p>
        You can reach the Home Assistant Guide team by email at:
        <br />
        <a href="mailto:hello@ha.top1pick.com"><strong>hello@ha.top1pick.com</strong></a>
      </p>

      <h2>What We Can Help With</h2>
      <ul>
        <li><strong>Setup questions</strong> — Help with Home Assistant configurations or integrations</li>
        <li><strong>Content suggestions</strong> — Topics or automations you'd like us to cover</li>
        <li><strong>Corrections</strong> — Found an error? Let us know and we'll fix it promptly</li>
        <li><strong>Partnership inquiries</strong> — Sponsored content or affiliate partnerships (subject to editorial standards)</li>
      </ul>

      <h2>Response Time</h2>
      <p>We aim to respond to all emails within 2–3 business days.</p>

      <p style="margin-top: 2rem; font-size: 0.9rem; color: var(--color-muted);">
        Home Assistant Guide is operated at <a href="https://ha.top1pick.com">ha.top1pick.com</a>.
      </p>
    </div>
  </div>
</BaseLayout>
